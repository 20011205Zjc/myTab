{
  "manifest_version": 3,
  "name": "myTab",
  "description": "Local-only new tab extension inspired by UITab.",
  "version": "0.1.0",
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "permissions": [
    "storage",
    "geolocation"
  ],
  "host_permissions": [
    "https://geocoding-api.open-meteo.com/*",
    "https://api.open-meteo.com/*",
    "https://api.openweathermap.org/*",
    "https://restapi.amap.com/*"
  ],
  "chrome_url_overrides": {
    "newtab": "newtab.html"
  }
}
